---
export const prerender = false;
import Layout from '@/layouts/layout.astro';
import crypto from 'node:crypto';

const token = Astro.url.searchParams.get('token');
const API_KEY = import.meta.env.LASTFM_API_KEY;
const API_SECRET = import.meta.env.LASTFM_API_SECRET;

let sessionKey = null;
let error = null;

if (token && API_KEY && API_SECRET) {
  try {
    const params: Record<string, string> = {
      api_key: API_KEY,
      method: 'auth.getSession',
      token: token,
    };

    const sortedKeys = Object.keys(params).sort();
    let sigString = '';
    for (const key of sortedKeys) {
      sigString += key + params[key];
    }
    sigString += API_SECRET;
    const api_sig = crypto.createHash('md5').update(sigString, 'utf8').digest('hex');

    const queryParams = new URLSearchParams({
      ...params,
      api_sig,
      format: 'json',
    });

    const response = await fetch('https://ws.audioscrobbler.com/2.0/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: queryParams.toString(),
    });

    const data = await response.json();
    if (data.session) {
      sessionKey = data.session.key;
    } else {
      error = data.message || 'Failed to get session';
    }
  } catch (e: any) {
    error = e.message;
  }
} else if (!token) {
  error = 'No token provided';
} else {
  error = 'API configuration missing';
}
---

<Layout>
  <div class="flex flex-col items-center justify-center min-h-[50vh] gap-4">
    <h1 class="text-2xl font-bold">Last.fm Authorization</h1>
    
    {error ? (
      <div class="p-4 bg-destructive/10 text-destructive rounded-lg border border-destructive/20 max-w-md text-center">
        <p class="font-semibold">Error</p>
        <p class="text-sm opacity-90">{error}</p>
        <a href="/listen" class="inline-block mt-4 text-primary hover:underline font-medium">Return to Radio</a>
      </div>
    ) : (
      <div class="flex flex-col items-center gap-4">
        <div class="h-8 w-8 animate-spin rounded-full border-4 border-primary border-t-transparent"></div>
        <p class="text-muted-foreground animate-pulse">Finalizing authorization and returning you to the radio...</p>
      </div>
    )}
  </div>

  {sessionKey && (
    <script define:vars={{ sessionKey }}>
      localStorage.setItem('lastfm_session', sessionKey);
      
      if (window.opener) {
        window.opener.postMessage({ type: 'lastfm_auth_success', sessionKey }, window.location.origin);
        setTimeout(() => window.close(), 1000);
      } else {
        setTimeout(() => {
          window.location.href = '/listen';
        }, 1000);
      }
    </script>
  )}
</Layout>
