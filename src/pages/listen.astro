---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { RadioPlayer } from '@/components/bento/RadioPlayer'
---

<Layout class="max-w-3xl">
  <Fragment slot="head">
    <PageHead title="Listen" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </Fragment>
  
  <Breadcrumbs items={[{ label: 'Listen', icon: 'lucide:radio' }]} />

  <section class="flex flex-col gap-6">
    <RadioPlayer client:load className="mx-auto w-full my-4" />

    <div class="prose">
      <p>
        A better implementation for the <a href="https://listen.moe/" target="_blank" rel="noopener noreferrer">LISTEN.moe</a> experience
        that:
        <ul>
          <li>Correctly sends metadata to media session (looks good on iDevice lock screen).</li>
          <li>Scrobbles what you listen to Last.fm.</li>
          <li>Attempts to look up the song on Spotify for that sweet sweet metadata.</li>
          <li>And freedom for more features I have not thought of / had time to implement, yet.</li>
        </ul>
      </p>
      <p>
        Press the 🎵 button to toggle scrobbling to Last.fm,
        and the -●- link to toggle scrobbling with Spotify's metadata.
      </p>
      <p>Leave this page open or play it in the background to enjoy J-Pop music continuous streaming.</p>
    </div>
  </section>
</Layout>
